---
import Layout from '../layouts/Layout.astro';
---

<Layout>

        <!-- Header-->
        <header class="bg-dark py-5">
            <div class="container px-4 px-lg-5 my-5">
                <div class="text-center text-white">
                    <h1 class="display-4 fw-bolder">Espejo - Frida Kahlo</h1>
                    <p class="lead fw-normal text-white-50 mb-0">Cada pieza nace desde el alma</p>
                </div>
            </div>
        </header>
        <!-- Product Details-->
        <section class="py-5">
            <div class="container px-4 px-lg-5 mt-5">
                <div class="row gx-4 gx-lg-5 align-items-center">
                    <div class="col-md-6">
                        <img class="card-img-top mb-5 mb-md-0" src="/assets/img/frida-kahlo.jpeg" alt="Espejo - Frida Kahlo" />
                    </div>
                    <div class="col-md-6">
                        <h2 class="display-5 fw-bolder">Descripción</h2>
                        <p class="lead"> Espejo decorativo inspirado en Frida Kahlo, realizado con vitrofusión, venecitas, muranos y azulejos. El diseño recrea su peinado y flores emblemáticas, evocando su espíritu fuerte y creativo.
                                        Cada pieza de vidrio y cerámica está ensamblada a mano, simbolizando la belleza de transformar lo fragmentado, tal como Frida convirtió su dolor en arte.
                                        No es solo un objeto decorativo: es un homenaje a la resiliencia, al poder femenino y a la autenticidad.
                        </p>
                        <p>Dimensiones: 45x65 cm<br>Material: Vidrio coloreado y espejo<br>Técnica: Mosaico decorativo</p>
                        <div class="d-flex">
                            <a class="btn btn-outline-dark flex-shrink-0" href="https://wa.me/5492215436779?text=Hola!%20te%20quería%20consultar%20sobre%20el%20cuadro%20de%20Frida%20Kahlo" target="_blank">
                                <i class="bi bi-whatsapp"></i> Consultar
                            </a>
                        </div>
                    </div>
                </div>
                <!-- More Images -->
                <div class="row gx-4 gx-lg-5 mt-5">
                    <h3 class="text-center mb-4">Más Fotos</h3>
                    <div class="col-md-4">
                        <img class="img-fluid rounded" src="/assets/img/frida-kahlo.jpeg" alt="Espejo - Frida Kahlo vista 1" />
                    </div>
                    <div class="col-md-4">
                        <img class="img-fluid rounded" src="/assets/img/portada.jpeg" alt="Espejo - Frida Kahlo vista 2" />
                    </div>
                    <div class="col-md-4">
                        <img class="img-fluid rounded" src="/assets/img/portada.jpeg" alt="Espejo - Frida Kahlo vista 3" />
                    </div>
                </div>
            </div>
        </section>
        <!-- Footer-->
        </Layout>