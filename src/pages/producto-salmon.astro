---
import Layout from '../layouts/Layout.astro';
---

<Layout>

        <!-- Header-->
        <header class="bg-dark py-5">
            <div class="container px-4 px-lg-5 my-5">
                <div class="text-center text-white">
                    <h1 class="display-4 fw-bolder">Salmón</h1>
                    <p class="lead fw-normal text-white-50 mb-0">Cada pieza nace desde el alma</p>
                </div>
            </div>
        </header>
        <!-- Product Details-->
        <section class="py-5">
            <div class="container px-4 px-lg-5 mt-5">
                <div class="row gx-4 gx-lg-5 align-items-center">
                    <div class="col-md-6">
                        <img class="card-img-top mb-5 mb-md-0" src="/assets/img/1.jpeg" alt="Salmón" />
                    </div>
                    <div class="col-md-6">
                        <h2 class="display-5 fw-bolder">Descripción</h2>
                        <p class="lead">Este hermoso mosaico de Salmón es una obra de arte única creada con pasión y dedicación. Cada tessera está colocada a mano para formar un patrón vibrante y lleno de vida. Perfecto para decorar cualquier espacio, este mosaico añade un toque de elegancia y color.</p>
                        <p>Dimensiones: 50x70 cm<br>Material: Vidrio y cerámica<br>Técnica: Mosaico tradicional</p>
                        <div class="d-flex">
                            <a class="btn btn-outline-dark flex-shrink-0" href="https://wa.me/5492215436779?text=Hola!%20te%20quería%20consultar%20sobre%20el%20cuadro%20Salmón" target="_blank">
                                <i class="bi bi-whatsapp"></i> Consultar
                            </a>
                        </div>
                    </div>
                </div>
                <!-- More Images -->
                <div class="row gx-4 gx-lg-5 mt-5">
                    <h3 class="text-center mb-4">Más Fotos</h3>
                    <div class="col-md-4">
                        <img class="img-fluid rounded" src="/assets/img/1.jpeg" alt="Salmón vista 1" />
                    </div>
                    <div class="col-md-4">
                        <img class="img-fluid rounded" src="/assets/img/portada.jpeg" alt="Salmón vista 2" />
                    </div>
                    <div class="col-md-4">
                        <img class="img-fluid rounded" src="/assets/img/portada.jpeg" alt="Salmón vista 3" />
                    </div>
                </div>
            </div>
        </section>
        <!-- Footer-->
        </Layout>